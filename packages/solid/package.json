{
  "name": "@sankyu/solid-circle-flags",
  "version": "0.1.5",
  "description": "400+ circular SVG Solid.js flags — tree-shakeable, TypeScript-ready, and Vite 8-compatible.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./meta": {
      "import": {
        "types": "./dist/meta.d.ts",
        "default": "./dist/meta.mjs"
      },
      "require": {
        "types": "./dist/meta.d.cts",
        "default": "./dist/meta.cjs"
      }
    },
    "./flags/*": {
      "import": {
        "types": "./dist/flags/*.d.ts",
        "default": "./dist/flags/*.mjs"
      },
      "require": {
        "types": "./dist/flags/*.d.cts",
        "default": "./dist/flags/*.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "postbuild": "node ../../scripts/life-cycle.js postbuild --pkg solid",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "solid",
    "solidjs",
    "flags",
    "country-flags",
    "svg",
    "typescript",
    "tree-shaking",
    "circle-flags"
  ],
  "author": "Sankyu Lab <opensource.sankyu-lab@xmsl.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SanKyu-Lab/circle-flags-ui.git",
    "directory": "packages/solid"
  },
  "bugs": {
    "url": "https://github.com/SanKyu-Lab/circle-flags-ui/issues"
  },
  "homepage": "https://github.com/SanKyu-Lab/circle-flags-ui/tree/main/packages/solid",
  "peerDependencies": {
    "solid-js": ">=1.0.0"
  },
  "dependencies": {
    "@sankyu/circle-flags-core": "^1.6.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild-plugin-solid": "^0.6.0",
    "jsdom": "^29.1.1",
    "solid-js": "^1.9.14",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite-plugin-solid": "^2.11.13",
    "vitest": "^4.1.10"
  }
}
