{
  "name": "@sankyu/svelte-circle-flags",
  "version": "0.0.1-beta.1",
  "description": "400+ circular SVG Svelte 5 flags — tree-shakeable, TypeScript-ready, and Vite 8-compatible.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./flags/*": {
      "types": "./dist/flags/*.svelte.d.ts",
      "svelte": "./dist/flags/*.svelte",
      "default": "./dist/flags/*.svelte"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "dev": "svelte-package --input src --watch",
    "build": "svelte-package --input src",
    "postbuild": "node ../../scripts/life-cycle.js postbuild --pkg svelte",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "svelte",
    "flags",
    "country-flags",
    "svg",
    "typescript",
    "tree-shaking",
    "circle-flags"
  ],
  "author": "Sankyu Lab <opensource.sankyu-lab@xmsl.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SanKyu-Lab/circle-flags-ui.git",
    "directory": "packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/SanKyu-Lab/circle-flags-ui/issues"
  },
  "homepage": "https://github.com/SanKyu-Lab/circle-flags-ui/tree/main/packages/svelte",
  "peerDependencies": {
    "svelte": ">=5.0.0"
  },
  "dependencies": {
    "@sankyu/circle-flags-core": "^1.6.6"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.11",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@testing-library/svelte": "^5.4.2",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "svelte": "^5.56.7",
    "svelte-check": "^4.7.3",
    "svelte-preprocess": "^6.0.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
