{
  "name": "@sankyu/svelte-circle-flags",
  "version": "0.0.1-beta.0",
  "description": "400+ circular SVG Svelte flags — tree-shakeable, TypeScript-ready, SSR-compatible, zero deps.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./flags/*.svelte": {
      "types": "./dist/flags/*.svelte.d.ts",
      "svelte": "./dist/flags/*.svelte"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "postbuild": "node ../../scripts/life-cycle.js postbuild --pkg svelte",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "svelte",
    "flags",
    "country-flags",
    "svg",
    "typescript",
    "tree-shaking",
    "circle-flags"
  ],
  "author": "Sankyu Lab <opensource.sankyu-lab@xmsl.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SanKyu-Lab/circle-flags-ui.git",
    "directory": "packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/SanKyu-Lab/circle-flags-ui/issues"
  },
  "homepage": "https://github.com/SanKyu-Lab/circle-flags-ui/tree/main/packages/svelte",
  "peerDependencies": {
    "svelte": ">=5.0.0"
  },
  "dependencies": {
    "@sankyu/circle-flags-core": "^1.5.4"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.10",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@testing-library/svelte": "^5.2.7",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild-svelte": "^0.9.5",
    "jsdom": "^28.1.0",
    "rollup-plugin-svelte": "^7.2.3",
    "svelte": "^5.28.6",
    "svelte-check": "^4.2.1",
    "svelte-preprocess": "^6.0.5",
    "svelte2tsx": "^0.7.56",
    "tsdown": "^0.22.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
