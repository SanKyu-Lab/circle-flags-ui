{
  "name": "@sankyu/react-circle-flags",
  "version": "1.6.7",
  "description": "400+ circular SVG React flags — tree-shakeable, TypeScript-ready, and SSR-compatible.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./meta": {
      "import": {
        "types": "./dist/meta.d.ts",
        "default": "./dist/meta.mjs"
      },
      "require": {
        "types": "./dist/meta.d.cts",
        "default": "./dist/meta.cjs"
      }
    },
    "./flags/*": {
      "import": {
        "types": "./dist/flags/*.d.ts",
        "default": "./dist/flags/*.mjs"
      },
      "require": {
        "types": "./dist/flags/*.d.cts",
        "default": "./dist/flags/*.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "postbuild": "node ../../scripts/life-cycle.js postbuild --pkg react",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "react",
    "flags",
    "country-flags",
    "svg",
    "typescript",
    "tree-shaking",
    "circle-flags"
  ],
  "author": "Sankyu Lab <opensource.sankyu-lab@xmsl.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SanKyu-Lab/circle-flags-ui.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/SanKyu-Lab/circle-flags-ui/issues"
  },
  "homepage": "https://react-circle-flags.js.org",
  "peerDependencies": {
    "react": ">=16.0.0"
  },
  "dependencies": {
    "@sankyu/circle-flags-core": "^1.6.6"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mocha": "^10.0.10",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
